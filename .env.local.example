# =============================================================================
# InsideWatch — Environment Variables
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored and must never be committed.
# =============================================================================


# ─── Supabase ─────────────────────────────────────────────────────────────────

# Project URL (safe to share — not a secret)
SUPABASE_URL=https://your-project.supabase.co

# ANON key — used by the Next.js frontend (read-only public access).
# This is the key you get from Supabase Dashboard → Settings → API → anon/public.
# It is NOT a secret per se (it is embedded in the frontend JS bundle) but
# must never be given write permissions via RLS policies.
SUPABASE_KEY=your-anon-public-key

# ─── Supabase service-role key (SCRAPER ONLY — NEVER expose to frontend) ──────
#
# The service_role key bypasses Row Level Security and can read/write/delete
# all data. Required once RLS is enabled on the database (Phase 1 step).
#
# How to get it:
#   Supabase Dashboard → Settings → API → service_role (secret)
#
# Where to set it:
#   • GitHub Actions: Settings → Secrets → Actions → SUPABASE_SERVICE_ROLE_KEY
#   • Local scraper: add to this file (python scraper reads it via os.getenv)
#
# DO NOT add NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY — that would expose it
# to every browser that loads the app.
#
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   ← uncomment when you have it


# ─── Optional Next.js-conventional aliases ────────────────────────────────────
# Only needed if a client component queries Supabase directly (not recommended).
# Safe to leave unset if SUPABASE_URL / SUPABASE_KEY above are set.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key


# ─── Email alerts (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=re_...
ALERT_EMAIL=you@example.com
ALERT_FROM_EMAIL=InsideWatch <alerts@yourdomain.com>


# ─── Telegram alerts ─────────────────────────────────────────────────────────
# Create a bot via @BotFather and add it to your channel.
# Both secrets are required; if either is absent, Telegram alerts are silently skipped.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=


# ─── Alert quality filters ────────────────────────────────────────────────────
#
# These control which transactions fire email/Telegram alerts.
# Raw transactions are always stored in the database regardless of these settings.
#
# Minimum total transaction value (EUR) to fire an alert.
# Default 50 000 = the MAR Art.19 single-transaction reporting threshold.
# Set to 0 to disable value filtering.
ALERT_MIN_VALUE_EUR=50000
#
# Exclude non-discretionary mechanical event types: grant, option_exercise,
# sell_to_cover, conversion, inheritance, gift_in/out, transfer_in/out,
# pledge_or_security, derivative_transaction.
# Set to false to receive alerts for all event types.
ALERT_EXCLUDE_MECHANICAL=true
#
# Suppress alerts for filings older than this many calendar days.
# Prevents alert floods during initial backfills and historical sweeps.
# MAR requires disclosure within 3 business days, so 5 days is a safe window.
# Set to 0 to disable age filtering (alerts fire for all filing ages).
ALERT_MAX_FILING_AGE_DAYS=5


# ─── Phase 3: Document storage ───────────────────────────────────────────────
#
# Where to store raw PDFs preserved immediately after download.
# 'local'    → filesystem under LOCAL_STORAGE_ROOT (dev/CI)
# 'supabase' → Supabase Storage bucket (production; requires the bucket to exist)
#
# Before using 'supabase': create a private bucket named 'filings-pdfs' in
#   Supabase Dashboard → Storage → New bucket (Public: OFF).
#
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./local_storage
SUPABASE_STORAGE_BUCKET=filings-pdfs


# ─── Phase 8: Internal operations console ────────────────────────────────────
# Password for HTTP Basic Auth protecting /internal/* and /api/internal/*.
# Generate with:  python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# Add to GitHub Secrets as INTERNAL_SECRET if deploying to Vercel/cloud.
INTERNAL_SECRET=change-me-before-use

# Label recorded in every internal_audit_log row to identify the acting operator.
# This is a SHARED LABEL — it does NOT provide individual user attribution.
# The current auth model is shared-admin (single password, single label).
# Replace with per-user identity before expanding console access.
# Defaults to "shared-admin" if unset.
INTERNAL_ACTOR_LABEL=shared-admin


# ─── Phase 9: Structured logging ─────────────────────────────────────────────
# Set to 'json' to emit NDJSON log lines (used in CI / log aggregation).
# Unset or 'text' for the human-readable default.
# LOG_FORMAT=json


# ─── Phase 10: Private API authentication ────────────────────────────────────
# Bearer token for /api/v1/* endpoints. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Set the same value in GitHub Secrets → INSIDEWATCH_API_KEY for CI health checks.
INSIDEWATCH_API_KEY=change-me-before-use
