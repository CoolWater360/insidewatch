# Supabase connection — shared by both the Python scraper and the Next.js app.
# The web app reads SUPABASE_URL/SUPABASE_KEY server-side (also accepts the
# NEXT_PUBLIC_* fallbacks below if you prefer the conventional Next naming).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# Optional Next.js-conventional aliases (only needed if a client component ever
# queries Supabase directly). Safe to leave unset if SUPABASE_* are set.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
